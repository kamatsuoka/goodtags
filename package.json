{
  "name": "goodtags",
  "version": "4.2.0",
  "private": true,
  "scripts": {
    "android": "expo run:android --no-bundler",
    "ios": "expo run:ios --no-bundler",
    "lint": "eslint . --format unix",
    "start": "react-native start",
    "test": "jest",
    "bump-package-version": "node deploy/bump-package-version.js",
    "bump-ios-version": "node deploy/bump-ios-versions.js",
    "bump-android-version": "node deploy/bump-android-version.js",
    "deploy:ios": "./deploy/deploy-ios.sh",
    "deploy:android": "./deploy/deploy-android.sh",
    "setup:android-signing": "./deploy/setup-android-signing.sh",
    "e2e:build:ios": "detox build --configuration ios.sim.release",
    "e2e:build:ios:debug": "detox build --configuration ios.sim.debug",
    "e2e:test:ios:release": "detox test --configuration ios.sim.release",
    "e2e:test:ios:verbose": "detox test --configuration ios.sim.release --loglevel verbose",
    "e2e:screenshots:ios": "./scripts/generate-screenshots.sh ios default",
    "e2e:screenshots:all": "./e2e/screenshots-all-sizes.sh",
    "screenshots:ios:release": "./scripts/maestro-screenshots.sh ios",
    "screenshots:ios:debug": "BUILD_TYPE=debug ./scripts/maestro-screenshots.sh ios",
    "screenshots:ios:6.5inch": "./scripts/maestro-screenshots.sh ios 6.5inch",
    "screenshots:ios:13inch": "./scripts/maestro-screenshots.sh ios 13inch",
    "screenshots:android:build": "cd android && ./gradlew assembleRelease",
    "screenshots:android:build:debug": "cd android && ./gradlew assembleDebug",
    "screenshots:android": "./scripts/maestro-screenshots.sh android",
    "screenshots:android:debug": "BUILD_TYPE=debug ./scripts/maestro-screenshots.sh android",
    "screenshots:all": "./scripts/maestro-screenshots.sh ios 6.5inch && ./scripts/maestro-screenshots.sh ios 13inch && ./scripts/maestro-screenshots.sh android",
    "screenshots:random-tag": "./scripts/maestro-screenshots.sh ios default random-tag.yaml"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.7",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "5.2.0",
    "@react-native-documents/picker": "^11.0.0",
    "@react-navigation/bottom-tabs": "^7.8.6",
    "@react-navigation/native": "^7.1.21",
    "@react-navigation/native-stack": "^7.7.0",
    "@reduxjs/toolkit": "^2.10.1",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.13.2",
    "expo": "^56.0.0",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-keep-awake": "~56.0.3",
    "expo-sqlite": "~56.0.5",
    "fast-xml-parser": "^5.3.2",
    "html-entities": "^2.6.0",
    "lodash": "^4.17.21",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.23.2",
    "react-native-device-info": "^15.0.1",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-error-boundary": "^3.1.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-paper": "^5.14.5",
    "react-native-pdf-renderer": "^2.3.0",
    "react-native-promise-rejection-utils": "^0.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-share": "^12.2.1",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "react-native-youtube-iframe": "^2.4.1",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^3.1.0",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "^0.85.3",
    "@react-native/eslint-config": "^0.85.3",
    "@react-native/metro-config": "^0.85.3",
    "@react-native/typescript-config": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~56.0.0",
    "baseline-browser-mapping": "^2.10.27",
    "detox": "^20.46.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.4",
    "hermes-eslint": "^0.36.1",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react-test-renderer": "19.2.3",
    "redux-mock-store": "^1.5.4",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "yarn@4.12.0"
}
